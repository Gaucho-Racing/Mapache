# Copy the contents of this file to `.env`

ENV="DEV"

DATABASE_HOST="db"
DATABASE_PORT="5432"
DATABASE_NAME="mapache"
DATABASE_USER="postgres"
DATABASE_PASSWORD="password"

# Sentinel SSO. CLIENT_ID is the dev SSO app — same across all
# developers, fine to commit. Fill in your own SECRET / TOKEN locally
# if you need to test auth flows; leave blank to ride SKIP_AUTH_CHECK.
SENTINEL_URL="https://sentinel-api.gauchoracing.com"
SENTINEL_JWKS_URL="https://sso.gauchoracing.com/.well-known/jwks.json"
SENTINEL_CLIENT_ID="z6V9NREjMFhf"
SENTINEL_CLIENT_SECRET=""
SENTINEL_TOKEN=""
SENTINEL_REDIRECT_URI="http://localhost:5173/auth/login"

# Mapbox token for the dashboard map. Optional — empty means the map
# tiles won't render but the rest of the dash is fine.
MAPBOX_ACCESS_TOKEN=""

# AWS creds for the shelter cold-storage ingest in gr26. Empty means
# any ingest job that gets claimed will fail at the S3 call; fine for
# local dev unless you're actually testing the parquet pipeline.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
